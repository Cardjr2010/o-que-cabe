{
  "version": 2,
  "functions": {
    "api/web.js": {
      "includeFiles": "api/static/**"
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/web.js"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/web.js"
    },
    {
      "source": "/teste-produtos",
      "destination": "/api/web.js"
    },
    {
      "source": "/teste-viagens",
      "destination": "/api/web.js"
    },
    {
      "source": "/mercadolivre-manual",
      "destination": "/api/web.js"
    },
    {
      "source": "/catalog",
      "destination": "/api/web.js"
    }
  ]
}
