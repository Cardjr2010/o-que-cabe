{
  "version": 2,
  "functions": {
    "api/web.js": {
      "includeFiles": "api/static/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/web.js"
    },
    {
      "source": "/",
      "destination": "/public/index.html"
    },
    {
      "source": "/app.js",
      "destination": "/public/app.js"
    },
    {
      "source": "/styles.css",
      "destination": "/public/styles.css"
    },
    {
      "source": "/favicon.svg",
      "destination": "/public/favicon.svg"
    },
    {
      "source": "/favicon.png",
      "destination": "/public/favicon.png"
    },
    {
      "source": "/logo-oqc.png",
      "destination": "/public/logo-oqc.png"
    },
    {
      "source": "/logo-oqc.svg",
      "destination": "/public/logo-oqc.svg"
    }
  ]
}
