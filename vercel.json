{
  "version": 2,
  "builds": [
    {
      "src": "api/web.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/public/index.html"
    },
    {
      "src": "/app.js",
      "dest": "/public/app.js"
    },
    {
      "src": "/styles.css",
      "dest": "/public/styles.css"
    },
    {
      "src": "/favicon.svg",
      "dest": "/public/favicon.svg"
    },
    {
      "src": "/favicon.png",
      "dest": "/public/favicon.png"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/api/(.*)",
      "dest": "api/web.js"
    },
    {
      "src": "/teste-produtos",
      "dest": "api/web.js"
    },
    {
      "src": "/teste-viagens",
      "dest": "api/web.js"
    },
    {
      "src": "/mercadolivre-manual",
      "dest": "api/web.js"
    },
    {
      "src": "/catalog",
      "dest": "api/web.js"
    }
  ]
}
